# Firebase Configuration
# Option 1: Paste your service account JSON here
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project-id",...}

# Option 2: Or set the path to your service account file
# GOOGLE_APPLICATION_CREDENTIALS=./path/to/serviceAccount.json

# Email Configuration (Brevo - required for OTP/verification emails)
# 1. Sign up at https://www.brevo.com (free tier: 300 emails/day)
# 2. Get API key from: Account > SMTP & API > API Keys
# 3. IMPORTANT: Verify your sender email in Brevo: Account > Senders & IP > Senders
BREVO_API_KEY=xkeysib-your-api-key-here
BREVO_SMTP_USER=your-verified-email@example.com
EMAIL_FROM=JolliReserve <your-verified-email@example.com>

# JWT Secret
JWT_SECRET=your_jwt_secret_here

# Optional: Keep for reference
# TURSO_DATABASE_URL=libsql://your-db.turso.io
# TURSO_AUTH_TOKEN=your-auth-token
